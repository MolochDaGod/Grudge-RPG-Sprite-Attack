# ==============================================
# GRUDGE RPG SPRITE ATTACK — Production (Coolify VPS)
# ==============================================
# Set these in Coolify → Application → Environment Variables

# ══════════════════════════════════════════════
# CORE
# ══════════════════════════════════════════════
NODE_ENV=production
PORT=5000

# ══════════════════════════════════════════════
# DATABASE — Grudge VPS PostgreSQL
# ══════════════════════════════════════════════
DATABASE_URL=postgresql://grudge:<password>@db.grudge-studio.com:5432/grudge_warlords?sslmode=require

# ══════════════════════════════════════════════
# AI PROVIDERS
# ══════════════════════════════════════════════
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
MESHY_API_KEY=

# ══════════════════════════════════════════════
# GRUDGE BACKEND SERVICES
# ══════════════════════════════════════════════
GRUDGE_GAME_API=https://api.grudge-studio.com
GRUDGE_ACCOUNT_API=https://account.grudge-studio.com
GRUDGE_ID_API=https://id.grudge-studio.com
OBJECTSTORE_WORKER_URL=https://objectstore.grudge-studio.com

# ══════════════════════════════════════════════
# AUTH
# ══════════════════════════════════════════════
SESSION_SECRET=
