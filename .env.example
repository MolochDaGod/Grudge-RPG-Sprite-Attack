# Core server/runtime
NODE_ENV=development
PORT=5000

# Database (required by server/db.ts and drizzle.config.ts)
# Local Docker Postgres default from docker-compose.yml
DATABASE_URL=postgresql://grudge:grudge@localhost:5432/grudge

# AI integrations used by server/replit_integrations/*
# If using OpenAI directly, keep base URL as official API
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# Meshy API integration used by server/meshyService.ts
MESHY_API_KEY=
