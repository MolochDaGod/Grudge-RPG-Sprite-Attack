# ==============================================
# GRUDGE RPG SPRITE ATTACK — Environment
# ==============================================
# Copy to .env and fill in your values. Never commit .env.

# ══════════════════════════════════════════════
# CORE
# ══════════════════════════════════════════════
NODE_ENV=development
PORT=5000

# ══════════════════════════════════════════════
# DATABASE — Grudge VPS PostgreSQL
# ══════════════════════════════════════════════
# Shared with all Grudge Studio apps (GDevelop Assistant, WCS, etc.)
# Local dev: use docker-compose postgres → localhost
# Production (Coolify): use db.grudge-studio.com
DATABASE_URL=postgresql://grudge:grudge@localhost:5432/grudge_warlords

# ══════════════════════════════════════════════
# AI PROVIDERS
# ══════════════════════════════════════════════
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
MESHY_API_KEY=

# ══════════════════════════════════════════════
# GRUDGE BACKEND SERVICES
# ══════════════════════════════════════════════
# Must match across all Grudge Studio apps
GRUDGE_GAME_API=https://api.grudge-studio.com
GRUDGE_ACCOUNT_API=https://account.grudge-studio.com
GRUDGE_ID_API=https://id.grudge-studio.com
OBJECTSTORE_WORKER_URL=https://objectstore.grudge-studio.com

# ══════════════════════════════════════════════
# PVP SERVER — Coolify VPS
# ══════════════════════════════════════════════
# Client-side env (VITE_ prefix exposed to browser)
VITE_PVP_SERVER_URL=https://pvp.grudge-studio.com

# ══════════════════════════════════════════════
# AUTH
# ══════════════════════════════════════════════
# JWT secret — must match across all Grudge Studio apps sharing accounts table
SESSION_SECRET=
